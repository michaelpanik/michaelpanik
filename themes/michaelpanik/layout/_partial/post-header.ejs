<%
const d = new Date(page.date)
const dtf = new Intl.DateTimeFormat('en', { year: 'numeric', month: 'long', day: 'numeric' }) 
const [{ value: mo },,{ value: da },,{ value: ye }] = dtf.formatToParts(d)
%>
<header class="blog-post__header" style="background-image:url(<%- page.cover %>)">
    <div class="container">
        <h1><%- page.title %></h1>
        <time><%- mo %> <%- da %>, <%- ye %></time>
        <%- partial('_partial/social-share', {
            title: page.title,
            url: url
        }) %>
    </div>
</header>