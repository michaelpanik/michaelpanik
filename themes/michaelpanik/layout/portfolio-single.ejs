<article class="page portfolio <%- page.slug %>">
    
    <h1><%- page.title %></h1>

    <% if (page.description) { %>
        <h2>Description</h2>
        <%- markdown(page.description) %>
    <% } %> 
    
    <% if (page.myRole) { %>
        <h2>My Role</h2>
        <%- markdown(page.myRole) %>
    <% } %> 
    
    <% if (page.content) { %>
        <hr>
        <section class="portfolio__content">
            <%- markdown(page.content) %>
        </section>
    <% } %> 
    
    <% if (page.stack) { %>
        <h2>Stack</h2>
        <ul class="stack">
            <% page.stack.forEach(function(item){ %>
                <%- partial('_partial/stack-icon', {item: item}) %>
                <% }); %>
            </ul>
    <% } %> 
</article>